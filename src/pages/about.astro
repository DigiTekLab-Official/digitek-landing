---
import Base from "../layouts/Base.astro";
import { services, stats } from "../data/projects.js";

const tintMap: Record<string, string> = {
  blue: "bg-tint-blue text-node-blue",
  red: "bg-tint-red text-node-red",
  green: "bg-tint-green text-node-green",
  purple: "bg-tint-purple text-node-purple",
};

const work = [
  {
    n: "01",
    color: "blue",
    t: "Understand the problem",
    d: "We study your business goals, customers, and existing workflows before designing the right solution.",
  },
  {
    n: "02",
    color: "green",
    t: "Build to operate",
    d: "We write clean, maintainable systems on modern stacks — and we build like we'll have to run it, because often we do.",
  },
  {
    n: "03",
    color: "purple",
    t: "Launch and improve",
    d: "After launch we keep measuring and improving through optimization, automation, and new features.",
  },
];
---

<Base
  title="About — Digitek Lab"
  description="Digitek Lab is a software studio whose roots go back to a 2002 computer & POS business (IC Tech). Today we build modern web, mobile, e-commerce, and AI products."
>
  <div class="mx-auto max-w-3xl px-5 sm:px-8">
    <section class="reveal py-16 sm:py-20">
      <p class="mb-4 font-mono text-xs uppercase tracking-widest text-faint">
        About
      </p>
      <h1 class="text-4xl font-800 leading-tight tracking-tight sm:text-5xl">
        A software studio with
        <span class="text-node-blue">two decades of roots.</span>
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-ink-soft">
        Digitek Lab is a software studio building web, mobile, e-commerce &amp;
        POS, and AI &amp; automation products. Our story starts in 2002 as
        <strong class="font-700 text-ink">IC Tech</strong>, a computer &amp; POS
        systems business serving local retailers and offices.
      </p>
      <p class="mt-4 text-lg leading-relaxed text-ink-soft">
        Digitek Lab is that company's modern continuation. The hardware-and-POS
        roots gave us a practical, business-first view of technology — and that
        enterprise background still shapes how we build software today: reliable,
        operable, and grounded in what a business actually needs.
      </p>
      <p class="mt-4 text-lg leading-relaxed text-ink-soft">
        Today we design, build, and operate 10+ live products in-house, run live
        online payments in production, and serve clients across India and the
        UAE from our base in Tamil Nadu.
      </p>
    </section>

    <!-- STATS -->
    <section class="reveal border-t border-line py-12">
      <dl class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-line bg-line sm:grid-cols-4">
        {
          stats.map((s) => (
            <div class="bg-panel p-5 text-center">
              <dt class="text-2xl font-800 tracking-tight text-ink">
                {s.value}
              </dt>
              <dd class="mt-1 text-xs leading-snug text-muted">{s.label}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    <!-- CAPABILITIES -->
    <section class="reveal border-t border-line py-14">
      <h2 class="mb-8 font-mono text-xs uppercase tracking-widest text-faint">
        What we build
      </h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {
          services.map((s) => (
            <div class="rounded-xl border border-line bg-panel p-5 shadow-card">
              <div
                class={`mb-3 flex h-9 w-9 items-center justify-center rounded-lg ${tintMap[s.color]} text-base font-700`}
              >
                +
              </div>
              <h3 class="font-700">{s.title}</h3>
              <p class="mt-1.5 text-sm text-muted">{s.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- HOW WE WORK -->
    <section class="reveal border-t border-line py-14">
      <h2 class="mb-8 font-mono text-xs uppercase tracking-widest text-faint">
        How we work
      </h2>
      <div class="space-y-5">
        {
          work.map((w) => (
            <div class="flex gap-4">
              <span
                class={`mt-0.5 font-mono text-sm font-600 ${tintMap[w.color].split(" ")[1]}`}
              >
                {w.n}
              </span>
              <div>
                <h3 class="font-700">{w.t}</h3>
                <p class="mt-1 text-sm text-muted">{w.d}</p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="reveal border-t border-line py-16 text-center">
      <h2 class="text-2xl font-800 tracking-tight">Have a product idea?</h2>
      <p class="mx-auto mt-3 max-w-md text-sm text-muted">
        Let's turn it into a modern, well-built digital product.
      </p>
      <a
        href="/contact"
        class="mt-6 inline-block rounded-lg bg-node-blue px-6 py-3 text-sm font-600 text-white transition-colors hover:bg-node-blue/90"
      >
        Start a conversation
      </a>
    </section>
  </div>
</Base>
