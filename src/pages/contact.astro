---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.jsx';

// ⚠️ EDIT THESE — placeholders. Set your correct details once.
const EMAIL = 'info@digiteklab.com';
const PHONE_DISPLAY = '+91 77082 76542';
const PHONE_RAW = '+917708276542';
const WHATSAPP = '917708276542'; // country code + number, no + or spaces
const LOCATION = 'Tamil Nadu, India';

const ICONS = {
  email: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  whatsapp: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>`,
  phone: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.58 3.44 2 2 0 0 1 3.55 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.13 6.13l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  location: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
};

const cards = [
  { tint: 'blue', label: 'Email', value: EMAIL, href: `mailto:${EMAIL}`, icon: ICONS.email },
  { tint: 'green', label: 'WhatsApp', value: PHONE_DISPLAY, href: `https://wa.me/${WHATSAPP}`, icon: ICONS.whatsapp },
  { tint: 'red', label: 'Phone', value: PHONE_DISPLAY, href: `tel:${PHONE_RAW}`, icon: ICONS.phone },
  { tint: 'purple', label: 'Location', value: LOCATION, href: null, icon: ICONS.location },
];

const tintMap: Record<string, string> = {
  blue: 'bg-tint-blue text-node-blue',
  green: 'bg-tint-green text-node-green',
  red: 'bg-tint-red text-node-red',
  purple: 'bg-tint-purple text-node-purple',
};
---

<Base title="Contact — Digitek Lab" description="Tell Digitek Lab what you're trying to build. Web, mobile, and custom software for businesses.">
  <div class="mx-auto max-w-5xl px-5 sm:px-8">
    <section class="reveal py-16 sm:py-20">
      <p class="mb-4 font-mono text-xs uppercase tracking-widest text-faint">Contact</p>
      <h1 class="text-4xl font-800 leading-tight tracking-tight sm:text-5xl">
        Let's talk about<br />what you're building.
      </h1>
      <p class="mt-5 max-w-lg text-lg text-muted">
        Share a few details and we'll come back with a clear, honest take on the
        fastest way to get it built.
      </p>
    </section>

    <section class="reveal grid gap-10 pb-20 lg:grid-cols-[1.3fr_1fr]">
      <ContactForm client:load />

      <div class="flex flex-col gap-3">
        {cards.map((c) => {
          const inner = (
            <div class="flex items-center gap-4">
              <span class={`flex h-11 w-11 items-center justify-center rounded-lg ${tintMap[c.tint]}`} set:html={c.icon} />
              <div>
                <p class="font-mono text-[11px] uppercase tracking-wider text-faint">{c.label}</p>
                <p class="text-sm font-600 text-ink">{c.value}</p>
              </div>
            </div>
          );
          return c.href ? (
            <a href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined} rel="noopener" class="rounded-xl border border-line bg-panel p-5 shadow-card transition-shadow hover:shadow-card-hover">{inner}</a>
          ) : (
            <div class="rounded-xl border border-line bg-panel p-5 shadow-card">{inner}</div>
          );
        })}

        <div class="mt-2 rounded-xl border border-line bg-panel p-5 shadow-card">
          <p class="mb-3 font-mono text-[11px] uppercase tracking-wider text-faint">Office hours</p>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between"><span class="text-muted">Mon – Fri</span><span class="text-ink">9:00 AM – 6:00 PM</span></div>
            <div class="flex justify-between"><span class="text-muted">Saturday</span><span class="text-ink">10:00 AM – 2:00 PM</span></div>
            <div class="flex justify-between"><span class="text-muted">Sunday</span><span class="text-node-red">Closed</span></div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Base>
