---
import Base from "../layouts/Base.astro";
import { services, process } from "../data/projects.js";

const serviceTint: Record<string, string> = {
  blue: "bg-tint-blue text-node-blue",
  red: "bg-tint-red text-node-red",
  green: "bg-tint-green text-node-green",
  purple: "bg-tint-purple text-node-purple",
};

const stepText: Record<string, string> = {
  blue: "text-node-blue",
  red: "text-node-red",
  green: "text-node-green",
  purple: "text-node-purple",
};
---

<Base
  title="Services — Digitek Lab"
  description="Web, mobile, e-commerce & POS, and AI & automation services from Digitek Lab — a software studio building technology since 2002."
>
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <section class="reveal py-16 sm:py-20">
      <p class="mb-4 font-mono text-xs uppercase tracking-widest text-faint">
        Services
      </p>
      <h1
        class="max-w-3xl text-4xl font-800 leading-tight tracking-tight sm:text-5xl"
      >
        Four pillars, one studio.
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-muted">
        We build web, mobile, e-commerce &amp; POS, and AI &amp; automation
        products — and we operate many of them ourselves. Here's what each
        practice covers.
      </p>
    </section>

    <section class="pb-8">
      <div class="grid gap-5 lg:grid-cols-2">
        {
          services.map((s) => (
            <article
              id={s.id}
              class="reveal scroll-mt-24 rounded-2xl border border-line bg-panel p-8 shadow-card"
            >
              <div
                class={`mb-5 flex h-12 w-12 items-center justify-center rounded-xl ${serviceTint[s.color]} text-xl font-700`}
              >
                +
              </div>
              <h2 class="text-xl font-800">{s.title}</h2>
              <p class="mt-3 text-sm leading-relaxed text-muted">{s.desc}</p>
              <ul class="mt-6 space-y-2.5 border-t border-line pt-6">
                {s.points.map((p) => (
                  <li class="flex gap-3 text-sm text-ink-soft">
                    <span
                      class={`mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full ${serviceTint[s.color]}`}
                    />
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </section>

    <!-- PROCESS -->
    <section class="reveal border-t border-line py-16 sm:py-20">
      <p class="mb-3 font-mono text-xs uppercase tracking-widest text-faint">
        How we work
      </p>
      <h2 class="text-3xl font-800 tracking-tight sm:text-4xl">
        A clear path from idea to launch
      </h2>

      <div
        class="mt-10 grid gap-px overflow-hidden rounded-2xl border border-line bg-line sm:grid-cols-2 lg:grid-cols-4"
      >
        {
          process.map((p) => (
            <div class="bg-panel p-7">
              <span class={`font-mono text-2xl font-700 ${stepText[p.color]}`}>
                {p.step}
              </span>
              <h3 class="mt-4 font-700">{p.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{p.desc}</p>
            </div>
          ))
        }
      </div>
    </section>
  </div>

  <section class="border-t border-line bg-surface">
    <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
      <div
        class="rounded-2xl border border-line bg-ink p-10 text-center sm:p-16"
      >
        <h2 class="text-3xl font-800 tracking-tight text-white sm:text-4xl">
          Not sure which pillar you need?
        </h2>
        <p class="mx-auto mt-3 max-w-md text-white/80">
          Tell us the problem. We'll point you to the fastest, most honest way to
          solve it — and where AI or automation actually helps.
        </p>
        <a
          href="/contact"
          class="mt-8 inline-block rounded-lg bg-white px-7 py-3.5 text-sm font-600 text-ink transition-colors hover:bg-white/90"
        >
          Start a project
        </a>
      </div>
    </div>
  </section>
</Base>
