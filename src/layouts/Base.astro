---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Reveal from "../components/Reveal.astro";

const {
  title = "Digitek Lab — Software studio for web, mobile, e-commerce & AI",
  description = "Digitek Lab is a software studio building web, mobile, e-commerce/POS, and AI & automation products. Building technology since 2002. India & UAE.",
} = Astro.props;

const nav = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/portfolio", label: "Work" },
  { href: "/about", label: "About" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo-transparent.png" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/logo.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-base text-ink font-sans antialiased">
    <Header nav={nav} />

    <main id="main">
      <slot />
    </main>

    <Footer />
    <Reveal />
  </body>
</html>
