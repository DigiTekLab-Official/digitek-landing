---
const year = new Date().getFullYear();

const columns = [
  {
    heading: "Company",
    links: [
      { href: "/about", label: "About" },
      { href: "/portfolio", label: "Work" },
      { href: "/contact", label: "Contact" },
    ],
  },
  {
    heading: "Services",
    links: [
      { href: "/services#web", label: "Web Development" },
      { href: "/services#mobile", label: "Mobile Apps" },
      { href: "/services#ecommerce", label: "E-commerce & POS" },
      { href: "/services#ai", label: "AI & Automation" },
    ],
  },
];

const social = [
  {
    label: "GitHub",
    href: "https://github.com",
    path: "M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z",
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com",
    path: "M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.8 0 0 .78 0 1.74v20.52C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.74V1.74C24 .78 23.2 0 22.22 0Z",
  },
  {
    label: "X",
    href: "https://x.com",
    path: "M18.9 1.5h3.7l-8.1 9.2L24 22.5h-7.4l-5.8-7.6-6.6 7.6H.5l8.6-9.9L0 1.5h7.6l5.2 6.9 6.1-6.9Zm-1.3 18.8h2L6.5 3.6h-2.2l13.3 16.7Z",
  },
];
---

<footer class="mt-24 border-t border-line bg-surface" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Site footer</h2>

  <div class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
    <div class="flex flex-col gap-10 lg:flex-row lg:justify-between">
      <!-- BRAND -->
      <div class="max-w-xs">
        <a href="/" class="flex items-center gap-2" aria-label="Digitek Lab — home">
          <img
            src="/logo-transparent.png"
            alt=""
            width="36"
            height="36"
            class="h-9 w-9"
            loading="lazy"
            decoding="async"
          />
          <span class="text-[15px] font-700 tracking-tight">
            Digitek <span class="text-node-blue">Lab</span>
          </span>
        </a>

        <p class="mt-4 text-sm text-muted">
          A software studio building web, mobile, e-commerce/POS, and AI &amp;
          automation products. Building technology since 2002.
        </p>

        <ul class="mt-6 flex items-center gap-3">
          {
            social.map((item) => (
              <li>
                <a
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={item.label}
                  class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-line text-muted transition-colors hover:border-node-blue/40 hover:text-ink"
                >
                  <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d={item.path} />
                  </svg>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- NAV COLUMNS -->
      <nav
        aria-label="Footer"
        class="grid grid-cols-2 gap-x-12 gap-y-8 sm:grid-cols-3"
      >
        {
          columns.map((col) => (
            <div>
              <h3 class="font-mono text-[11px] uppercase tracking-wider text-faint">
                {col.heading}
              </h3>
              <ul class="mt-3 space-y-2 text-sm">
                {col.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-muted transition-colors hover:text-ink"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }

        <div>
          <h3 class="font-mono text-[11px] uppercase tracking-wider text-faint">
            Get in touch
          </h3>
          <ul class="mt-3 space-y-2 text-sm">
            <li>
              <a
                href="mailto:info@digiteklab.com"
                class="text-muted transition-colors hover:text-ink"
              >
                info@digiteklab.com
              </a>
            </li>
            <li class="text-muted">Tamil Nadu, India</li>
            <li class="text-muted">Serving India &amp; UAE</li>
          </ul>
        </div>
      </nav>
    </div>

    <div
      class="mt-12 flex flex-col gap-2 border-t border-line pt-6 text-xs text-faint sm:flex-row sm:items-center sm:justify-between"
    >
      <p>&copy; {year} Digitek Lab. Building technology since 2002.</p>
      <p>Made in Tamil Nadu, India · Serving India &amp; UAE</p>
    </div>
  </div>
</footer>
